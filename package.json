{
  "name": "noonchi",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "db:migrate": "pnpm --filter scripts migrate",
    "db:seed": "pnpm --filter scripts seed",
    "test:regression": "pnpm --filter tests regression",
    "test:scenarios": "pnpm --filter tests test:scenarios",
    "test:migration": "pnpm --filter tests regression",
    "test:migration:integration": "pnpm --filter tests migration:integration",
    "test:count": "pnpm --filter @noonchi/shared test:count"
  },
  "dependencies": {
    "next": "16.2.6"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
