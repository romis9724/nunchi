# ── LLM ────────────────────────────────────────────────────────────────────
# Gemini (무료): https://aistudio.google.com → Get API Key
GEMINI_API_KEY=
# 선택: 기본값은 gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Ollama (로컬 fallback — GEMINI_API_KEY가 없을 때만 사용)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:latest

# ── DATABASE ────────────────────────────────────────────────────────────────
# 방법 A (추천): Supabase 연결 문자열 직접 사용
# Supabase → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:[비밀번호]@db.xxxx.supabase.co:5432/postgres

# 방법 B: Supabase SDK용 (waitlist API 등에서 사용)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── 이메일 (선택) ────────────────────────────────────────────────────────────
# Resend (무료 100통/일): https://resend.com
# RESEND_API_KEY=re_...

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
